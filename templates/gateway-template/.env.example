# x402 Gateway Configuration
LISTEN_ADDR=:8402

# Payee locking script (hex P2PKH) — receives service payments
PAYEE_LOCKING_SCRIPT_HEX=76a914YOUR_PUBKEY_HASH_HERE88ac

# Pool keys (WIF format)
# NONCE_WIF=your_nonce_pool_private_key
# FEE_WIF=your_fee_pool_private_key

# Redis (optional, for persistent pools)
# REDIS_URL=redis://localhost:6379

# Challenge TTL in seconds
CHALLENGE_TTL=300

# Template mode (Profile B)
# TEMPLATE_MODE=false

# BSV network
BSV_NETWORK=mainnet
